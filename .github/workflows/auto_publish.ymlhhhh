name: Auto Publish Videos

on:
  schedule:
    # Run every 4 hours for continuous posting:
    # 0:00, 4:00, 8:00, 12:00, 16:00, 20:00 UTC
    # This ensures continuous content even when no new videos are added
    - cron: '0 */4 * * *'
  workflow_dispatch: # Allow manual trigger

jobs:
  publish-videos:
    runs-on: ubuntu-latest
    timeout-minutes: 60  # Increased timeout for processing multiple videos

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'  # Cache pip dependencies for faster runs
      
      - name: Install FFmpeg
        run: |
          sudo apt-get update
          sudo apt-get install -y ffmpeg
      
      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
      
      - name: Check secrets (non-blocking)
        run: |
          echo "=============================================="
          echo "🔍 CHECKING SECRETS STATUS"
          echo "=============================================="
          echo ""
          
          # Dropbox (REQUIRED for fetching videos)
          if [ -n "${DROPBOX_APP_KEY}" ] && [ -n "${DROPBOX_REFRESH_TOKEN}" ]; then
            echo "✅ DROPBOX: Configured - Will fetch videos"
          else
            echo "⚠️  DROPBOX: Not configured - Cannot fetch videos"
          fi
          
          # Instagram
          if [ -n "${INSTAGRAM_ACCESS_TOKEN}" ]; then
            echo "✅ INSTAGRAM: Configured - Will upload reels/stories"
          else
            echo "⚠️  INSTAGRAM: Not configured - Will skip Instagram"
          fi
          
          # Facebook
          if [ -n "${FACEBOOK_ACCESS_TOKEN}" ]; then
            echo "✅ FACEBOOK: Configured - Will upload reels/stories"
          else
            echo "⚠️  FACEBOOK: Not configured - Will skip Facebook"
          fi
          
          # Threads
          if [ -n "${THREADS_ACCESS_TOKEN}" ]; then
            echo "✅ THREADS: Configured - Will upload"
          else
            echo "⚠️  THREADS: Not configured - Will skip Threads"
          fi
          
          # YouTube
          if [ -n "${YT_REFRESH_TOKEN}" ]; then
            echo "✅ YOUTUBE: Configured - Will upload shorts"
          else
            echo "⚠️  YOUTUBE: Not configured - Will skip YouTube"
          fi
          
          # AI Caption
          if [ -n "${POLLINATIONS_API_KEY}" ]; then
            echo "✅ AI CAPTIONS: Configured - Will generate unique captions"
          else
            echo "⚠️  AI CAPTIONS: Not configured - Will use default captions"
          fi
          
          echo ""
          echo "=============================================="
          echo "🚀 PIPELINE WILL CONTINUE REGARDLESS OF STATUS"
          echo "=============================================="
          echo ""
        env:
          DROPBOX_APP_KEY: ${{ secrets.DROPBOX_APP_KEY }}
          DROPBOX_REFRESH_TOKEN: ${{ secrets.DROPBOX_REFRESH_TOKEN }}
          INSTAGRAM_ACCESS_TOKEN: ${{ secrets.INSTAGRAM_ACCESS_TOKEN }}
          FACEBOOK_ACCESS_TOKEN: ${{ secrets.FACEBOOK_ACCESS_TOKEN }}
          THREADS_ACCESS_TOKEN: ${{ secrets.THREADS_ACCESS_TOKEN }}
          YT_REFRESH_TOKEN: ${{ secrets.YT_REFRESH_TOKEN }}
          POLLINATIONS_API_KEY: ${{ secrets.POLLINATIONS_API_KEY }}
      
      - name: Run automation pipeline
        env:
          # Dropbox
          DROPBOX_APP_KEY: ${{ secrets.DROPBOX_APP_KEY }}
          DROPBOX_APP_SECRET: ${{ secrets.DROPBOX_APP_SECRET }}
          DROPBOX_ACCESS_TOKEN: ${{ secrets.DROPBOX_ACCESS_TOKEN }}
          DROPBOX_REFRESH_TOKEN: ${{ secrets.DROPBOX_REFRESH_TOKEN }}
          DROPBOX_FOLDER: /margot
          LOCAL_INPUT_DIR: Videos
          
          # Instagram
          INSTAGRAM_ACCESS_TOKEN: ${{ secrets.INSTAGRAM_ACCESS_TOKEN }}
          INSTAGRAM_ACCOUNT_ID: ${{ secrets.INSTAGRAM_ACCOUNT_ID }}
          
          # Facebook
          FACEBOOK_ACCESS_TOKEN: ${{ secrets.FACEBOOK_ACCESS_TOKEN }}
          FACEBOOK_PAGE_ID: ${{ secrets.FACEBOOK_PAGE_ID }}
          
          # Threads
          THREADS_ACCESS_TOKEN: ${{ secrets.THREADS_ACCESS_TOKEN }}
          THREADS_USER_ID: ${{ secrets.THREADS_USER_ID }}
          
          # YouTube (optional)
          YT_CLIENT_ID: ${{ secrets.YT_CLIENT_ID }}
          YT_CLIENT_SECRET: ${{ secrets.YT_CLIENT_SECRET }}
          YT_REFRESH_TOKEN: ${{ secrets.YT_REFRESH_TOKEN }}
          
          # AI Caption
          POLLINATIONS_API_KEY: ${{ secrets.POLLINATIONS_API_KEY }}
          AI_MODEL: openai
        run: |
          echo "Starting automation pipeline..."
          python auto_pipeline.py
          exit_code=$?
          
          if [ $exit_code -ne 0 ]; then
            echo "❌ Pipeline failed with exit code $exit_code"
            exit $exit_code
          fi
          
          echo "✅ Pipeline completed successfully"
      
      - name: Commit published videos log
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          
          # Add only the log file (not large video files)
          git add published_videos.json 2>/dev/null || true
          
          # Only commit if there are changes
          if ! git diff --staged --quiet; then
            git commit -m "Update published videos log [skip ci]"
            git push
            echo "✅ Committed and pushed published_videos.json"
          else
            echo "ℹ️ No changes to commit"
          fi
